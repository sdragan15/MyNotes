<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="MyNotes.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:MyNotes.View"
    xmlns:viewmodel="clr-namespace:MyNotes.ViewModel"
    xmlns:model="clr-namespace:MyNotes.Application.Model;assembly=MyNotes.Application"
    x:DataType="viewmodel:AppShellViewModel"
    Shell.FlyoutBehavior="Flyout"
    Shell.FlyoutBackgroundColor="#F3F7F2"
    Title="MyNotes">

    <!-- Route definitions only -->
    <FlyoutItem Title="Todos" FlyoutItemIsVisible="False">
        <ShellContent ContentTemplate="{DataTemplate local:MainPage}" Route="MainPage" />
    </FlyoutItem>
    <FlyoutItem Title="Notes" FlyoutItemIsVisible="False">
        <ShellContent ContentTemplate="{DataTemplate local:NotesPage}" Route="NotesPage" />
    </FlyoutItem>

    <Shell.FlyoutContent>
        <ScrollView BackgroundColor="#F3F7F2">
            <VerticalStackLayout Spacing="0">

                <!-- Header -->
                <Grid Padding="16,20,16,16" BackgroundColor="#3A5E35">
                    <VerticalStackLayout Spacing="2">
                        <Label Text="MyNotes"
                               FontAttributes="Bold"
                               FontSize="22"
                               TextColor="#F3F7F2" />
                        <BoxView HeightRequest="2"
                                 WidthRequest="32"
                                 BackgroundColor="#A8C4A2"
                                 HorizontalOptions="Start" />
                    </VerticalStackLayout>
                </Grid>

                <BoxView HeightRequest="1" BackgroundColor="#E2EBE0" />

                <!-- Todos -->
                <Grid Padding="16,13" ColumnDefinitions="Auto,*" BackgroundColor="Transparent">
                    <Image Grid.Column="0" Source="todo.svg"
                           HeightRequest="22" WidthRequest="22" VerticalOptions="Center" />
                    <Label Grid.Column="1" Text="Todos"
                           TextColor="#1C2B18" FontSize="15" Margin="14,0,0,0" VerticalOptions="Center" />
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding NavigateToTodosCommand}" />
                    </Grid.GestureRecognizers>
                </Grid>

                <BoxView HeightRequest="1" BackgroundColor="#E2EBE0" />

                <!-- Notes (all notes) -->
                <Grid Padding="16,13" ColumnDefinitions="Auto,*" BackgroundColor="Transparent">
                    <Image Grid.Column="0" Source="notes.svg"
                           HeightRequest="22" WidthRequest="22" VerticalOptions="Center" />
                    <Label Grid.Column="1" Text="Notes"
                           TextColor="#1C2B18" FontSize="15" Margin="14,0,0,0" VerticalOptions="Center" />
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding NavigateToAllNotesCommand}" />
                    </Grid.GestureRecognizers>
                </Grid>

                <BoxView HeightRequest="1" BackgroundColor="#E2EBE0" />

                <!-- Categories (expandable) -->
                <Grid Padding="16,13" ColumnDefinitions="Auto,*,Auto" BackgroundColor="Transparent">
                    <Image Grid.Column="0" Source="notes.svg"
                           HeightRequest="22" WidthRequest="22" VerticalOptions="Center" />
                    <Label Grid.Column="1" Text="Categories"
                           TextColor="#1C2B18" FontSize="15" Margin="14,0,0,0" VerticalOptions="Center" />
                    <Label Grid.Column="2" Text="›"
                           TextColor="#5C7A56" FontSize="20" VerticalOptions="Center"
                           Rotation="{Binding ChevronRotation}" />
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ToggleCategoriesExpandedCommand}" />
                    </Grid.GestureRecognizers>
                </Grid>

                <!-- Category sub-items -->
                <VerticalStackLayout IsVisible="{Binding IsCategoriesExpanded}" Spacing="0">
                    <BindableLayout.ItemsSource>
                        <Binding Path="Categories" />
                    </BindableLayout.ItemsSource>
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="model:CategoryDto">
                            <Grid Padding="50,10,16,10" ColumnDefinitions="Auto,*" BackgroundColor="Transparent">
                                <BoxView Grid.Column="0"
                                         WidthRequest="4" HeightRequest="4" CornerRadius="2"
                                         BackgroundColor="#7A9C74" VerticalOptions="Center" />
                                <Label Grid.Column="1"
                                       Text="{Binding Name}"
                                       TextColor="#1C2B18" FontSize="14"
                                       Margin="10,0,0,0" VerticalOptions="Center" />
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type Shell}}, Path=BindingContext.SelectCategoryCommand}"
                                        CommandParameter="{Binding .}" />
                                </Grid.GestureRecognizers>
                            </Grid>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </Shell.FlyoutContent>

</Shell>
