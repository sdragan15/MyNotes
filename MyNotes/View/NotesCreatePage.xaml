<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MyNotes.View.NotesCreatePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewmodel="clr-namespace:MyNotes.ViewModel"
    x:DataType="viewmodel:NotesCreateViewModel"
    Title="Create note"
    BackgroundColor="#F3F7F2"
    Shell.BackgroundColor="#3A5E35"
    Shell.TitleColor="#F3F7F2"
    Shell.ForegroundColor="#F3F7F2">

    <ContentPage.ToolbarItems>
        <ToolbarItem
            IconImageSource="iconscheck.svg"
            Command="{Binding CreateCommand}" />
    </ContentPage.ToolbarItems>

    <Grid Padding="16,12" RowDefinitions="Auto,Auto,Auto,Auto,*">

        <!-- Title field -->
        <Label Grid.Row="0"
               Text="Title"
               FontSize="11"
               FontAttributes="Bold"
               TextColor="#7A9C74"
               Margin="4,0,0,4" />

        <Border Grid.Row="1"
                BackgroundColor="White"
                Stroke="#C8DEC4"
                StrokeThickness="1"
                StrokeShape="{RoundRectangle CornerRadius=8}"
                Padding="12,4"
                Margin="0,0,0,12">
            <Entry x:Name="HeaderEntry"
                   Placeholder="Enter title..."
                   PlaceholderColor="#A8C4A2"
                   Text="{Binding HeadTitle, Mode=TwoWay}"
                   TextColor="#1C2B18"
                   FontAttributes="Bold"
                   FontSize="16"
                   ReturnType="Next"
                   BackgroundColor="Transparent" />
        </Border>

        <!-- Category picker -->
        <Label Grid.Row="2"
               Text="Category"
               FontSize="11"
               FontAttributes="Bold"
               TextColor="#7A9C74"
               Margin="4,0,0,4" />

        <Border Grid.Row="3"
                BackgroundColor="White"
                Stroke="#C8DEC4"
                StrokeThickness="1"
                StrokeShape="{RoundRectangle CornerRadius=8}"
                Padding="8,0"
                Margin="0,0,0,12">
            <Picker ItemsSource="{Binding Categories}"
                    SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"
                    ItemDisplayBinding="{Binding Name}"
                    TextColor="#1C2B18"
                    TitleColor="#A8C4A2"
                    BackgroundColor="Transparent"
                    FontSize="14" />
        </Border>

        <!-- Body field -->
        <Border Grid.Row="4"
                BackgroundColor="White"
                Stroke="#C8DEC4"
                StrokeThickness="1"
                StrokeShape="{RoundRectangle CornerRadius=8}"
                Padding="12,8">
            <Editor x:Name="BodyEditor"
                    Placeholder="Type your note..."
                    PlaceholderColor="#A8C4A2"
                    Text="{Binding Body, Mode=TwoWay}"
                    TextColor="#1C2B18"
                    FontSize="14"
                    AutoSize="Disabled"
                    VerticalOptions="FillAndExpand"
                    HorizontalOptions="FillAndExpand"
                    MaxLength="20000"
                    BackgroundColor="Transparent" />
        </Border>

    </Grid>
</ContentPage>
