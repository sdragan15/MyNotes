<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MyNotes.View.NotesPage"
             Title="Notes"
             x:Name="NotesPageView"
             xmlns:model="clr-namespace:MyNotes.Application.Model;assembly=MyNotes.Application"
             xmlns:viewmodel="clr-namespace:MyNotes.ViewModel"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:DataType="viewmodel:NotesViewModel">
    <Grid RowDefinitions="Auto, *, Auto">
        <FlexLayout Grid.Row="0" 
                    Wrap="Wrap" 
                    Direction="Row"
                    AlignItems="Start"
                    JustifyContent="SpaceAround"
                    Padding="10"
                    BindableLayout.ItemsSource="{Binding NoteItems}">
            <BindableLayout.ItemTemplate>
                <DataTemplate x:DataType="model:NotesDto">
                    <ContentView>
                        <Border
                            BackgroundColor="Green"
                            Padding="15"
                            Stroke="#003390ff"
                            StrokeThickness="2"
                            StrokeShape="{RoundRectangle CornerRadius=12}">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding IsSelected}"
                                    Value="True">
                                    <Setter Property="Stroke" Value="#3390ff"/>
                                </DataTrigger>
                            </Border.Triggers>
                            <VerticalStackLayout 
                                x:Name="note" 
                                Spacing="10" 
                                MaximumWidthRequest="130" 
                                MaximumHeightRequest="100"
                                MinimumWidthRequest="50">

                                <Label  Text="{Binding Header}" 
                                    FontAttributes="Bold" 
                                    FontSize="Header"
                                    LineBreakMode="TailTruncation"
                                    MaxLines="1">
                                </Label>
                                <Label  Text="{Binding Content}"
                                    LineBreakMode="TailTruncation"
                                    MaxLines="3"/>
                            </VerticalStackLayout>
                        </Border>
                        <ContentView.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EditItemCommand}"
                                CommandParameter="{Binding .}" />
                        </ContentView.GestureRecognizers>
                        <!--<ContentView.Behaviors>
                            <toolkit:TouchBehavior
                                LongPressDuration="1000"
                                LongPressCommand="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SelectNoteCommand}"
                                LongPressCommandParameter="{Binding .}"/>
                        </ContentView.Behaviors>-->
                    </ContentView>

                </DataTemplate>
            </BindableLayout.ItemTemplate>
        </FlexLayout>
        <Button Grid.Row="2"
                Text="Create"
                Command="{Binding CreateItemCommand}"
                Margin="20" />
    </Grid>
    
</ContentPage>