<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MyNotes.View.NotesPage"
             Title="Notes"
             x:Name="NotesPageView"
             xmlns:model="clr-namespace:MyNotes.Application.Model;assembly=MyNotes.Application"
             xmlns:viewmodel="clr-namespace:MyNotes.ViewModel"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:DataType="viewmodel:NotesViewModel"
             BackgroundColor="#F3F7F2"
             Shell.BackgroundColor="#3A5E35"
             Shell.TitleColor="#F3F7F2"
             Shell.ForegroundColor="#F3F7F2">

    <Grid RowDefinitions="*,Auto" Padding="16,10">

        <CollectionView Grid.Row="0" ItemsSource="{Binding NoteItems}" IsGrouped="True">
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical"
                                 Span="2"
                                 HorizontalItemSpacing="10"
                                 VerticalItemSpacing="10" />
            </CollectionView.ItemsLayout>
            <CollectionView.GroupHeaderTemplate>
                <DataTemplate x:DataType="viewmodel:NotesGroup">
                    <Grid ColumnDefinitions="*,Auto,*" Margin="0,6,0,2">
                        <BoxView Grid.Column="0"
                                 HeightRequest="1"
                                 BackgroundColor="#C8DEC4"
                                 VerticalOptions="Center" />
                        <Label Grid.Column="1"
                               Text="{Binding DateLabel}"
                               TextColor="#7A9C74"
                               FontSize="11"
                               Margin="10,0"
                               VerticalOptions="Center" />
                        <BoxView Grid.Column="2"
                                 HeightRequest="1"
                                 BackgroundColor="#C8DEC4"
                                 VerticalOptions="Center" />
                    </Grid>
                </DataTemplate>
            </CollectionView.GroupHeaderTemplate>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="model:NotesDto">
                    <SwipeView Margin="0,0,0,0">
                        <SwipeView.RightItems>
                            <SwipeItems Mode="Execute">
                                <SwipeItemView Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteNoteCommand}"
                                               CommandParameter="{Binding .}">
                                    <Border BackgroundColor="#C0392B"
                                            Stroke="Transparent"
                                            StrokeShape="{RoundRectangle CornerRadius=10}"
                                            Padding="20,0"
                                            Margin="6,0,0,0">
                                        <Label Text="Delete"
                                               TextColor="White"
                                               FontAttributes="Bold"
                                               FontSize="13"
                                               VerticalOptions="Center"
                                               HorizontalOptions="End" />
                                    </Border>
                                </SwipeItemView>
                            </SwipeItems>
                        </SwipeView.RightItems>
                        <Border BackgroundColor="White"
                                Stroke="#C8DEC4"
                                StrokeThickness="1"
                                StrokeShape="{RoundRectangle CornerRadius=10}"
                                Padding="12">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="{Binding Header}"
                                       FontAttributes="Bold"
                                       FontSize="14"
                                       TextColor="#1C2B18"
                                       LineBreakMode="TailTruncation"
                                       MaxLines="1" />
                                <BoxView HeightRequest="1" BackgroundColor="#E2EBE0" />
                                <Label Text="{Binding Content}"
                                       FontSize="12"
                                       TextColor="#5C7A56"
                                       LineBreakMode="TailTruncation"
                                       MaxLines="4" />
                            </VerticalStackLayout>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EditItemCommand}"
                                    CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>
                        </Border>
                    </SwipeView>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button Grid.Row="1"
                Text="Create"
                Command="{Binding CreateItemCommand}"
                BackgroundColor="#4A7A41"
                TextColor="White"
                CornerRadius="6"
                FontAttributes="Bold"
                Margin="0,10,0,0" />
    </Grid>

</ContentPage>