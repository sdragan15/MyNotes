<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup
    x:Class="MyNotes.View.ItemCreatePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:viewmodel="clr-namespace:MyNotes.ViewModel"
    x:DataType="viewmodel:ItemCreateViewModel"
    CanBeDismissedByTappingOutsideOfPopup="True"
    Color="Transparent"
    Size="360,210">

    <Border BackgroundColor="#F3F7F2"
            Stroke="#3A5E35"
            StrokeThickness="1"
            StrokeShape="{RoundRectangle CornerRadius=10}">

        <Grid RowDefinitions="4,*">

            <!-- Accent bar at top -->
            <BoxView Grid.Row="0"
                     BackgroundColor="#4A7A41"
                     HeightRequest="4">
                <BoxView.Clip>
                    <RoundRectangleGeometry CornerRadius="10,10,0,0" Rect="0,0,360,4" />
                </BoxView.Clip>
            </BoxView>

            <VerticalStackLayout Grid.Row="1" Spacing="14" Padding="20,16,20,20">

                <Label Text="New Task"
                       FontSize="15"
                       FontAttributes="Bold"
                       TextColor="#1C2B18" />

                <Border BackgroundColor="#E2EBE0"
                        Padding="12,8"
                        Stroke="Transparent"
                        StrokeThickness="0"
                        StrokeShape="{RoundRectangle CornerRadius=6}">
                    <Entry x:Name="Input"
                           Text="{Binding Text}"
                           Placeholder="I should..."
                           PlaceholderColor="#7A9C74"
                           TextColor="#1C2B18"
                           ReturnCommand="{Binding DoneCommand}"
                           ReturnType="Done"
                           BackgroundColor="Transparent" />
                </Border>

                <FlexLayout Direction="Row" AlignItems="Stretch" JustifyContent="Start">
                    <Button Text="Done"
                            Command="{Binding DoneCommand}"
                            BackgroundColor="#4A7A41"
                            TextColor="White"
                            CornerRadius="6"
                            FontAttributes="Bold"
                            FlexLayout.Basis="0%"
                            FlexLayout.Grow="1" />
                    <BoxView WidthRequest="10" BackgroundColor="Transparent" IsVisible="{Binding IsEdit}" />
                    <Button Text="Delete"
                            IsVisible="{Binding IsEdit}"
                            Command="{Binding DeleteCommand}"
                            BackgroundColor="Transparent"
                            TextColor="#C0392B"
                            BorderColor="#C0392B"
                            BorderWidth="1"
                            CornerRadius="6"
                            FontAttributes="Bold"
                            FlexLayout.Basis="0%"
                            FlexLayout.Grow="1" />
                </FlexLayout>

            </VerticalStackLayout>
        </Grid>
    </Border>
</toolkit:Popup>
