<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:model="clr-namespace:MyNotes.Application.Model;assembly=MyNotes.Application"
             xmlns:viewmodel="clr-namespace:MyNotes.ViewModel"
             x:DataType="viewmodel:MainViewModel"
             Title="{Binding Title}"
             x:Class="MyNotes.View.MainPage"
             BackgroundColor="#F3F7F2"
             Shell.BackgroundColor="#3A5E35"
             Shell.TitleColor="#F3F7F2"
             Shell.ForegroundColor="#F3F7F2">

    <Grid RowDefinitions="*,Auto" Padding="16,10">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="2">

                <!-- Active todos grouped by date -->
                <CollectionView ItemsSource="{Binding TodoGroups}" IsGrouped="True">
                    <CollectionView.GroupHeaderTemplate>
                        <DataTemplate x:DataType="viewmodel:TodoGroup">
                            <Grid ColumnDefinitions="*,Auto,*" Margin="0,6,0,2">
                                <BoxView Grid.Column="0" HeightRequest="1" BackgroundColor="#C8DEC4" VerticalOptions="Center" />
                                <Label Grid.Column="1" Text="{Binding DateLabel}"
                                       TextColor="#7A9C74" FontSize="11" Margin="10,0" VerticalOptions="Center" />
                                <BoxView Grid.Column="2" HeightRequest="1" BackgroundColor="#C8DEC4" VerticalOptions="Center" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.GroupHeaderTemplate>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="model:ItemDto">
                            <Grid Padding="4,6" ColumnDefinitions="Auto,*">
                                <CheckBox Grid.Column="0"
                                          Color="#4A7A41"
                                          IsChecked="{Binding IsChecked}"
                                          VerticalOptions="Center" />
                                <Label Grid.Column="1"
                                       Text="{Binding Text}"
                                       TextColor="#1C2B18"
                                       LineBreakMode="WordWrap"
                                       HorizontalOptions="FillAndExpand"
                                       VerticalOptions="Center">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EditItemCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Label.GestureRecognizers>
                                </Label>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Done todos grouped by completion date -->
                <CollectionView ItemsSource="{Binding DoneGroups}" IsGrouped="True">
                    <CollectionView.GroupHeaderTemplate>
                        <DataTemplate x:DataType="viewmodel:TodoGroup">
                            <Grid ColumnDefinitions="*,Auto,*" Margin="0,6,0,2">
                                <BoxView Grid.Column="0" HeightRequest="1" BackgroundColor="#C8DEC4" VerticalOptions="Center" />
                                <Label Grid.Column="1" Text="{Binding DateLabel}"
                                       TextColor="#7A9C74" FontSize="11" Margin="10,0" VerticalOptions="Center" />
                                <BoxView Grid.Column="2" HeightRequest="1" BackgroundColor="#C8DEC4" VerticalOptions="Center" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.GroupHeaderTemplate>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="model:ItemDto">
                            <Grid Padding="4,6" ColumnDefinitions="Auto,*">
                                <CheckBox Grid.Column="0"
                                          Color="#A8C4A2"
                                          IsChecked="{Binding IsChecked}"
                                          VerticalOptions="Center" />
                                <Label Grid.Column="1"
                                       Text="{Binding Text}"
                                       TextColor="#7A9C74"
                                       TextDecorations="Strikethrough"
                                       LineBreakMode="WordWrap"
                                       HorizontalOptions="FillAndExpand"
                                       VerticalOptions="Center" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>

        <Button Grid.Row="1"
                Text="Create"
                Command="{Binding OpenPopupCommand}"
                BackgroundColor="#4A7A41"
                TextColor="White"
                CornerRadius="6"
                FontAttributes="Bold"
                Margin="0,10,0,0" />
    </Grid>

</ContentPage>
